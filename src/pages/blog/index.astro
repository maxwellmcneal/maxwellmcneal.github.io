---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogListing from '../../components/BlogListing.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect every unique tag across all posts (Tutorial Unit 5 pattern).
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description="All blog posts.">
	<BlogListing
		posts={posts}
		allTags={allTags}
		heading="Blog Posts"
		subheading="Enjoy reading some of my posts"
	/>
</BaseLayout>
