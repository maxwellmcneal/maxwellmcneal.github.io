---
// A squiggly divider drawn as a repeating SVG wave with a solid accent stroke.
// Uses currentColor so it picks up `text-accent` and recolors in dark mode.
//
// The wave is a <pattern> tiled in userSpaceOnUse units, so one period is a
// fixed 60px regardless of how wide/tall the container is — the squiggle keeps
// the same wavelength and simply repeats more times to fill the space (instead
// of stretching, which is what preserveAspectRatio="none" used to do).
//
// One tile is two half-waves (up bump + down bump) returning to the centre, so
// adjacent tiles join seamlessly.
interface Props {
	orientation?: 'horizontal' | 'vertical';
}
const { orientation = 'horizontal' } = Astro.props;
const horizontal = orientation === 'horizontal';

// Unique id so multiple squiggles on one page don't share a <pattern>.
const id = `squiggle-${crypto.randomUUID().slice(0, 8)}`;

// Half-wave width in px. Smaller = tighter wavelength. Full tile = 2 * HALF.
const HALF = 15;
const TILE = HALF * 2;
const path = horizontal
	? `M0 9 q ${HALF / 2} -4 ${HALF} 0 t ${HALF} 0`
	: `M9 0 q -4 ${HALF / 2} 0 ${HALF} t 0 ${HALF}`;
---

{
	horizontal ? (
		<svg class="block w-full text-accent" height="18" fill="none" aria-hidden="true">
			<defs>
				<pattern id={id} width={TILE} height="18" patternUnits="userSpaceOnUse">
					<path d={path} stroke="currentColor" stroke-width="3" stroke-linecap="round" />
				</pattern>
			</defs>
			<rect width="100%" height="18" fill={`url(#${id})`} />
		</svg>
	) : (
		<svg class="block h-full text-accent" width="18" fill="none" aria-hidden="true">
			<defs>
				<pattern id={id} width="18" height={TILE} patternUnits="userSpaceOnUse">
					<path d={path} stroke="currentColor" stroke-width="3" stroke-linecap="round" />
				</pattern>
			</defs>
			<rect width="18" height="100%" fill={`url(#${id})`} />
		</svg>
	)
}
